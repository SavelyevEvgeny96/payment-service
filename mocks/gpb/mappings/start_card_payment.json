{
  "request": {
    "method": "POST",
    "urlPathPattern": "/payment/gpb/card/.*/payment/.*/start",
    "headers": {
      "Content-Type": {
        "matches": "application/json.*"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "delayDistribution": {
      "type": "uniform",
      "lower": 150,
      "upper": 2500
    },
    "jsonBody": {
      "token": "{{randomValue length=33 type='ALPHANUMERIC'}}",
      "options": {
        "paymentPageUrl": "http://www.sogaz.ru"
      }
    }
  }
}
