{
  "request": {
    "method": "POST",
    "urlPathPattern": "/payment/gpb/card/.*/token",
    "headers": {
      "Content-Type": {
        "matches": "application/json.*"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "delayDistribution": {
      "type": "uniform",
      "lower": 150,
      "upper": 5000
    },
    "jsonBody": {
      "error": null,
      "token": "{{randomValue length=33 type='ALPHANUMERIC'}}",
      "timestamp": "{{now}}"
    }
  }
}
